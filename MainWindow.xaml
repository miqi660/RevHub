<Window x:Class="ForzaUDPReader.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ForzaUDPReader.WPF.Controls"
        xmlns:converters="clr-namespace:ForzaUDPReader.WPF.Converters"
        Title="Forza Horizon 6 - Telemetry HUD"
        Width="648" Height="180"
        MinWidth="500" MinHeight="130"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        FontFamily="{StaticResource ForzaFont}">

    <Window.Resources>
        <converters:TurnsToDegreeConverter x:Key="TurnsToDegree"/>
        <converters:LenientDoubleConverter x:Key="LenientDouble" Min="0.01" Max="255.0"/>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 齿轮按钮样式 -->
        <!-- ═══════════════════════════════════════════ -->
        <Style x:Key="GearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 关闭按钮样式 -->
        <!-- ═══════════════════════════════════════════ -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════ -->
        <!-- 控制按钮组淡入/淡出动画 -->
        <!-- ═══════════════════════════════════════════ -->
        <Style x:Key="ControlPanelStyle" TargetType="StackPanel">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!--
        层叠布局：
        - 底层：数据展示区（Viewbox 等比缩放，HorizontalAlignment="Left" 防止居中留黑边）
        - 上层：控制按钮 + Popup
    -->
    <Grid>
        <!-- ======== 底层：数据展示区（Viewbox 等比缩放） ======== -->
        <Border Background="#141B22" CornerRadius="4" Margin="4"
                HorizontalAlignment="Left">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Left">
                <Grid x:Name="InnerGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ChartColumn" Width="Auto"/>
                        <ColumnDefinition Width="89"/>
                        <ColumnDefinition Width="251"/>
                    </Grid.ColumnDefinitions>

                    <controls:ChartControl x:Name="Chart" Grid.Column="0" Margin="10" Width="227"/>
                    <controls:PedalsControl x:Name="Pedals" Grid.Column="1" Margin="5,10,221,10" Grid.ColumnSpan="2"/>

                    <Grid Grid.Column="2" Margin="5,10,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="81"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <controls:RpmLedControl x:Name="RpmLed" Grid.Row="0" Margin="10,0,-23,0"/>
                            <controls:GearControl x:Name="Gear" Grid.Row="1" Margin="16,0,-17,37" Grid.RowSpan="2"/>
                            <controls:SpeedControl x:Name="Speed" Grid.Row="2" VerticalAlignment="Center" Margin="10,0,-23,0" Height="40"/>
                        </Grid>

                        <controls:SteeringControl x:Name="Steering" Grid.Column="1"
                                                  Width="138" HorizontalAlignment="Left" Margin="18,0,0,0"/>
                    </Grid>
                </Grid>
            </Viewbox>
        </Border>

        <!-- ======== 右上角：齿轮 + 关闭 按钮组 ======== -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,4,4,0"
                    Style="{StaticResource ControlPanelStyle}">
            <Button x:Name="GearButton" Content="⚙"
                    Style="{StaticResource GearButtonStyle}"
                    Click="OnGearButtonClick"/>
            <Button Content="×"
                    Style="{StaticResource CloseButtonStyle}"
                    Click="OnCloseButtonClick"
                    Margin="4,0,0,0"/>
        </StackPanel>

        <!-- ======== 透明度调节 Popup ======== -->
        <Popup x:Name="OpacityPopup"
               PlacementTarget="{Binding ElementName=GearButton}"
               Placement="Bottom"
               StaysOpen="False"
               HorizontalOffset="-60"
               VerticalOffset="4">
            <Border Background="#2D2D2D" CornerRadius="6" Padding="12,8"
                    BorderBrush="#555" BorderThickness="1">
                <StackPanel>
                    <!-- 透明度调节 -->
                    <TextBlock Text="HUD 透明度" Foreground="#CCC"
                               FontSize="11" Margin="0,0,0,6"/>
                    <Slider x:Name="OpacitySlider" Width="140"
                            Minimum="0.1" Maximum="1.0"
                            Value="{Binding Opacity, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                            TickFrequency="0.1" IsSnapToTickEnabled="False"/>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="#555" Margin="0,10,0,8"/>

                    <!-- 最左侧踏板显示模式 -->
                    <TextBlock Text="最左侧踏板显示" Foreground="#CCC"
                               FontSize="11" Margin="0,0,0,6"/>
                    <RadioButton x:Name="RbClutch" Content="离合 (Clutch)"
                                 Foreground="#CCC" FontSize="11"
                                 GroupName="LeftPedal" IsChecked="True"
                                 Margin="0,0,0,4"
                                 Checked="OnPedalModeChanged"/>
                    <RadioButton x:Name="RbHandbrake" Content="手刹 (Handbrake)"
                                 Foreground="#CCC" FontSize="11"
                                 GroupName="LeftPedal"
                                 Checked="OnPedalModeChanged"/>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="#555" Margin="0,10,0,8"/>

                    <!-- 显示/隐藏开度曲线 -->
                    <CheckBox x:Name="ShowTraceToggle" Content="显示开度曲线 (Show Trace)"
                              Foreground="#CCC" FontSize="11"
                              IsChecked="True"
                              Checked="OnShowTraceToggled"
                              Unchecked="OnShowTraceToggled"/>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="#555" Margin="0,10,0,8"/>

                    <!-- 方向盘单边圈数设置 -->
                    <TextBlock Text="方向盘单边圈数 (Turns)" Foreground="#CCC"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock Text="可输入0.01~255.00, 用于设置单边旋转圈数" Foreground="#888"
                               FontSize="9" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TurnsInput" Width="60"
                                 FontSize="11" Padding="2,1"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SingleSideTurns,
                                        Source={x:Reference Steering},
                                        Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged,
                                        Converter={StaticResource LenientDouble}}"/>

                        <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11">
                            <TextBlock.Text>
                                <Binding Path="SingleSideTurns"
                                         Source="{x:Reference Steering}"
                                         Converter="{StaticResource TurnsToDegree}"
                                         FallbackValue="±180°"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
