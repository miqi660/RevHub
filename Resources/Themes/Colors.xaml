<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ 背景色 ═══ -->
    <SolidColorBrush x:Key="BgDarkColor" Color="#141B22"/>
    <SolidColorBrush x:Key="BgMediumColor" Color="#1E2530"/>
    <SolidColorBrush x:Key="BgLightColor" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BgCardColor" Color="#252D38"/>
    <SolidColorBrush x:Key="BgHoverColor" Color="#3A3A3A"/>

    <!-- ═══ 前景色 ═══ -->
    <SolidColorBrush x:Key="FgPrimaryColor" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="FgSecondaryColor" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="FgMutedColor" Color="#888888"/>
    <SolidColorBrush x:Key="FgAccentColor" Color="#CCC"/>

    <!-- ═══ 强调色 ═══ -->
    <SolidColorBrush x:Key="AccentBlueColor" Color="#4A6EE0"/>
    <SolidColorBrush x:Key="AccentGreenColor" Color="#4CD964"/>
    <SolidColorBrush x:Key="AccentRedColor" Color="#FF6B4A"/>
    <SolidColorBrush x:Key="AccentYellowColor" Color="#FFCC00"/>
    <SolidColorBrush x:Key="AccentOrangeColor" Color="#FFA500"/>

    <!-- ═══ 边框色 ═══ -->
    <SolidColorBrush x:Key="BorderColor" Color="#555555"/>
    <SolidColorBrush x:Key="BorderLightColor" Color="#3A3A3A"/>

    <!-- ═══ 状态色 ═══ -->
    <SolidColorBrush x:Key="StatusConnectedColor" Color="#4CD964"/>
    <SolidColorBrush x:Key="StatusDisconnectedColor" Color="#888888"/>
    <SolidColorBrush x:Key="StatusErrorColor" Color="#FF6B4A"/>

</ResourceDictionary>
