<Application x:Class="RevHub.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RevHub.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 主题资源 -->
                <ResourceDictionary Source="Resources/Themes/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Templates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 全局转换器 -->
            <conv:TestButtonContentConverter x:Key="TestButtonContentConverter"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:PedalModeConverter x:Key="PedalModeConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

            <!-- 全局自定义字体资源 -->
            <FontFamily x:Key="ForzaFont">pack://application:,,,/Fonts/#sui-generis-free, Arial Black</FontFamily>
            <FontFamily x:Key="HudFont">pack://application:,,,/Fonts/#sui-generis-free</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
