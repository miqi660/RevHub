<UserControl x:Class="ForzaUDPReader.WPF.Controls.GearControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        档位大号显示 (R / N / 1-16)
        字号 36pt × 1.33 ≈ 48 DIP
        使用 MainWindow 中定义的 HudFont 资源
    -->
    <TextBlock x:Name="GearText" Text="N"
               FontFamily="{StaticResource HudFont}"
               FontSize="64" FontWeight="Bold"
               Foreground="#FFCC00"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
</UserControl>
